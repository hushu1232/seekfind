# ============================================================
#  求问 — 环境配置模板
#  复制此文件为 .env 并根据实际情况修改
# ============================================================

# --- 服务端口 ---
BFF_PORT=8700
CHROMA_PORT=8000

# --- 模型策略：local | cloud | hybrid | enterprise ---
# local:     仅本地 Ollama（零成本，8GB+ 显存）
# cloud:     仅云端 API（需 API Key + 联网 + 付费）
# hybrid:    本地优先，失败后自动降级云端（推荐）
# enterprise: 企业模式，本地优先 + 企业 API 备选（面向企业培训）
MODEL_STRATEGY=hybrid

# --- 本地模型 (Ollama) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- 云端模型 (hybrid 模式下的兜底) ---
CLOUD_API_BASE_URL=https://api.openai.com/v1
CLOUD_API_KEY=
CLOUD_MODEL=gpt-4o-mini

# --- 自动降级阈值：本地模型连续 N 次工具调用失败后切换云端 ---
FALLBACK_THRESHOLD=3

# ============================================================
#  企业版配置（T4.3 - 面向企业员工培训）
# ============================================================

# --- 企业 API（本地不可用时的备选方案）---
# 企业内部部署的 API 服务
# ENTERPRISE_API_BASE_URL=https://api.company.com/v1
# ENTERPRISE_API_KEY=sk-xxx
# ENTERPRISE_MODEL=gpt-4o

# --- 企业降级策略 ---
# ENTERPRISE_AUTO_FALLBACK=true     # 本地不可用时自动降级
# ENTERPRISE_NOTIFY_USER=true       # 降级时通知用户
# ENTERPRISE_PRIVACY_WARNING=true   # 降级时显示隐私警告

# --- 企业部署配置 ---
# ENTERPRISE_DEPLOYMENT_MODE=false  # 企业批量部署模式
# ENTERPRISE_AUTO_UPDATE=true       # 自动更新知识库
# ENTERPRISE_SHARED_KNOWLEDGE=true  # 共享知识库（多用户）
# ENTERPRISE_AUDIT_LOG=false        # 审计日志（记录所有操作）

# ============================================================
#  Chroma 向量库
# ============================================================
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_DOCS=qiuwen_docs
CHROMA_COLLECTION_ELEMENTS=qiuwen_elements
CHROMA_COLLECTION_FLOWS=qiuwen_flows

# --- 日志级别 ---
LOG_LEVEL=INFO

# --- 隐私 ---
PRIVACY_SANITIZE_ENABLED=true
PRIVACY_HISTORY_LEARNING_ENABLED=false
