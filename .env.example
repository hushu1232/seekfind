# ============================================================
#  求问 — 环境配置模板
#  复制此文件为 .env 并根据实际情况修改
# ============================================================

# --- 服务端口 ---
BFF_PORT=8700
CHROMA_PORT=8000

# --- 模型策略：local | cloud | hybrid ---
MODEL_STRATEGY=hybrid

# --- 本地模型 (Ollama) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- 云端模型 (hybrid 模式下的兜底) ---
CLOUD_API_BASE_URL=https://api.openai.com/v1
CLOUD_API_KEY=
CLOUD_MODEL=gpt-4o-mini

# --- 自动降级阈值：本地模型连续 N 次工具调用失败后切换云端 ---
FALLBACK_THRESHOLD=3

# --- Chroma 向量库 ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_DOCS=qiuwen_docs
CHROMA_COLLECTION_ELEMENTS=qiuwen_elements
CHROMA_COLLECTION_FLOWS=qiuwen_flows

# --- 日志级别 ---
LOG_LEVEL=INFO

# --- 隐私 ---
PRIVACY_SANITIZE_ENABLED=true
PRIVACY_HISTORY_LEARNING_ENABLED=false
